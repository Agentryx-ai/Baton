{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["logical_works", "unmatched_codex", "unmatched_claude"],
  "properties": {
    "logical_works": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "work_id", "project_cwd", "confidence", "match_rationale",
          "codex_session_ids", "claude_session_ids", "target_codex_session_id",
          "target_claude_session_id", "recommended_action", "goal_action",
          "proposed_goal", "context_message", "evidence_refs", "warnings"
        ],
        "properties": {
          "work_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
          "project_cwd": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "match_rationale": { "type": "string", "maxLength": 12000 },
          "codex_session_ids": { "type": "array", "maxItems": 256, "items": { "type": "string", "pattern": "^[0-9a-fA-F-]{36}$" } },
          "claude_session_ids": { "type": "array", "maxItems": 256, "items": { "type": "string", "pattern": "^[0-9a-fA-F-]{36}$" } },
          "target_codex_session_id": { "type": ["string", "null"] },
          "target_claude_session_id": { "type": ["string", "null"] },
          "recommended_action": {
            "type": "string",
            "enum": ["apply_to_codex", "apply_to_claude", "manual_review", "no_action"]
          },
          "goal_action": { "type": "string", "enum": ["keep", "replace", "none"] },
          "proposed_goal": { "type": "string", "maxLength": 20000 },
          "context_message": { "type": "string", "maxLength": 50000 },
          "evidence_refs": { "type": "array", "maxItems": 512, "items": { "type": "string", "maxLength": 4096 } },
          "warnings": { "type": "array", "maxItems": 128, "items": { "type": "string", "maxLength": 4096 } }
        }
      }
    },
    "unmatched_codex": { "type": "array", "items": { "type": "string" } },
    "unmatched_claude": { "type": "array", "items": { "type": "string" } }
  }
}
