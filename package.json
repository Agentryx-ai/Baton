{
  "name": "baton",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "baton": "scripts/baton-cli.mjs"
  },
  "scripts": {
    "dev": "concurrently -n web,bff -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "start": "tsx server/index.ts",
    "status": "node scripts/baton-cli.mjs status",
    "test": "node scripts/run-isolated-tests.mjs",
    "typecheck": "tsc -b --noEmit",
    "lint": "oxlint",
    "smoke:codex-adapter": "tsx scripts/codex-adapter-smoke.ts",
    "smoke:claude-native": "tsx scripts/claude-native-canary.ts",
    "smoke:codex-plugins": "tsx scripts/codex-plugin-account-canary.ts",
    "migrate:legacy-accounts": "tsx scripts/migrate-legacy-cliproxy-accounts.ts",
    "repair:claude-accounts": "tsx scripts/repair-claude-native-accounts.ts",
    "build:bootstrap": "node scripts/build-baton-bootstrap.mjs",
    "install:bootstrap:dev": "node scripts/build-baton-bootstrap.mjs --install --allow-unsigned-development",
    "verify:bootstrap": "node scripts/verify-baton-bootstrap.mjs",
    "restore:native-goals": "tsx scripts/restore-native-goals.ts",
    "purge:native-imports": "tsx scripts/purge-native-imports.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "lucide-react": "^1.25.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "smol-toml": "^1.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
